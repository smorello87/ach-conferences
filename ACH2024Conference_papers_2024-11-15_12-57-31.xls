    <Cell><ss:Data ss:Type="String">77.0</ss:Data></Cell>
    <Cell><ss:Data ss:Type="String">80.0</ss:Data></Cell>
    <Cell><ss:Data ss:Type="String">74.0</ss:Data></Cell>
