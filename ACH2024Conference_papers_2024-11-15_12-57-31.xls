    <Cell><ss:Data ss:Type="String"></ss:Data></Cell>
    <Cell><ss:Data ss:Type="String">53.0</ss:Data></Cell>
    <Cell><ss:Data ss:Type="String">64.0</ss:Data></Cell>
    <Cell><ss:Data ss:Type="String">44.0</ss:Data></Cell>
    <Cell><ss:Data ss:Type="String">0</ss:Data></Cell>
    <Cell><ss:Data ss:Type="String">2</ss:Data></Cell>
    <Cell><ss:Data ss:Type="String">2</ss:Data></Cell>
    <Cell><ss:Data ss:Type="String">0</ss:Data></Cell>
