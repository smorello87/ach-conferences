    <Cell><ss:Data ss:Type="String">Steelberg, Tierney;&#10;Purcell, Sarah</ss:Data></Cell>
    <Cell><ss:Data ss:Type="String">steelber@grinnell.edu;&#10;purcelsj@grinnell.edu</ss:Data></Cell>
    <Cell><ss:Data ss:Type="String"></ss:Data></Cell>
    <Cell><ss:Data ss:Type="String"></ss:Data></Cell>
    <Cell><ss:Data ss:Type="String">0</ss:Data></Cell>
    <Cell><ss:Data ss:Type="String">Central Time</ss:Data></Cell>
    <Cell><ss:Data ss:Type="String">0</ss:Data></Cell>
