    <Cell><ss:Data ss:Type="String">corey.clawson@rutgers.edu</ss:Data></Cell>
    <Cell><ss:Data ss:Type="String"></ss:Data></Cell>
    <Cell><ss:Data ss:Type="String">corey.clawson@rutgers.edu, justin.clawson@usu.edu, bruce.richards@usu.edu, rhonda.miller@usu.edu, shawn.barstow@usu.edu</ss:Data></Cell>
    <Cell><ss:Data ss:Type="String">Clawson, Corey;&#10;Clawson, Justin</ss:Data></Cell>
    <Cell><ss:Data ss:Type="String">corey.clawson@rutgers.edu;&#10;justin.clawson@usu.edu</ss:Data></Cell>
    <Cell><ss:Data ss:Type="String"></ss:Data></Cell>
    <Cell><ss:Data ss:Type="String"></ss:Data></Cell>
    <Cell><ss:Data ss:Type="String">0</ss:Data></Cell>
    <Cell><ss:Data ss:Type="String">East Coast US</ss:Data></Cell>
    <Cell><ss:Data ss:Type="String">0</ss:Data></Cell>
    <Cell><ss:Data ss:Type="String"></ss:Data></Cell>
    <Cell><ss:Data ss:Type="String"></ss:Data></Cell>
    <Cell><ss:Data ss:Type="Number">3</ss:Data></Cell>
    <Cell><ss:Data ss:Type="Number">0</ss:Data></Cell>
