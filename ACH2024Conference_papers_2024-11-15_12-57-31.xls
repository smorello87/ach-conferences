    <Cell><ss:Data ss:Type="String">Visa, Sofia;&#10;Hayward, Jennifer;&#10;Mangubi, Marina;&#10;Sene, Ibra;&#10;Riley, Evan;&#10;Kilimo, Miriam;&#10;Hermann, Mareike;&#10;Nikoi, Nii;&#10;Palmer, Dan;&#10;Deeter, Caitlyn;&#10;Holt, Katie;&#10;Atay, Ahmet;&#10;Craven, Christa</ss:Data></Cell>
    <Cell><ss:Data ss:Type="String">svisa@wooster.edu;&#10;JHAYWARD@wooster.edu;&#10;MMANGUBI@wooster.edu;&#10;ISene@wooster.edu;&#10;ERiley@wooster.edu;&#10;mkilimo@wooster.edu;&#10;MHERRMANN@wooster.edu;&#10;nnikoi@wooster.edu;&#10;danpalmer@wooster.edu;&#10;cdeeter@wooster.edu;&#10;KHolt@wooster.edu;&#10;aatay@wooster.edu;&#10;CCraven@wooster.edu</ss:Data></Cell>
    <Cell><ss:Data ss:Type="String"></ss:Data></Cell>
