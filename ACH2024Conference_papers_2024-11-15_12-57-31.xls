    <Cell><ss:Data ss:Type="String">meghan.ferriter@gmail.com, samantha@zooniverse.org, Mia.Ridge@bl.uk</ss:Data></Cell>
    <Cell><ss:Data ss:Type="String">Ferriter, Meghan;&#10;Blickhan, Samantha;&#10;Ridge, Mia</ss:Data></Cell>
    <Cell><ss:Data ss:Type="String">meghan.ferriter@gmail.com;&#10;samantha@zooniverse.org;&#10;Mia.Ridge@bl.uk</ss:Data></Cell>
    <Cell><ss:Data ss:Type="String"></ss:Data></Cell>
    <Cell><ss:Data ss:Type="String"></ss:Data></Cell>
    <Cell><ss:Data ss:Type="String">0</ss:Data></Cell>
    <Cell><ss:Data ss:Type="String">GMT; ET; CT</ss:Data></Cell>
