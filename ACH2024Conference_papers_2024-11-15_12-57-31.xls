    <Cell><ss:Data ss:Type="String">coenhenr@grinnell.edu</ss:Data></Cell>
    <Cell><ss:Data ss:Type="String">Coen, Henry Gallop</ss:Data></Cell>
    <Cell><ss:Data ss:Type="String">coenhenr@grinnell.edu</ss:Data></Cell>
    <Cell><ss:Data ss:Type="String"></ss:Data></Cell>
    <Cell><ss:Data ss:Type="String"></ss:Data></Cell>
    <Cell><ss:Data ss:Type="String">1</ss:Data></Cell>
    <Cell><ss:Data ss:Type="String">central time</ss:Data></Cell>
    <Cell><ss:Data ss:Type="String">0</ss:Data></Cell>
