    <Cell ss:StyleID="s22"><Data ss:Type="DateTime">2024-09-07T17:19:23.000</Data></Cell>
    <Cell><ss:Data ss:Type="Number">1000</ss:Data></Cell>
    <Cell><ss:Data ss:Type="String"></ss:Data></Cell>
    <Cell><ss:Data ss:Type="String">Liz Grumbach</ss:Data></Cell>
    <Cell ss:StyleID="s22"><Data ss:Type="DateTime">2024-06-06T21:03:05.000</Data></Cell>
    <Cell><ss:Data ss:Type="String"></ss:Data></Cell>
    <Cell><ss:Data ss:Type="Number">109</ss:Data></Cell>
    <Cell><ss:Data ss:Type="Number">1</ss:Data></Cell>
    <Cell><ss:Data ss:Type="String">D2-S1-B</ss:Data></Cell>
    <Cell><ss:Data ss:Type="String">#8B: Design Studio: Towards Repair/Refusal in the Digital Humanities (Alternate Format)</ss:Data></Cell>
    <Cell><ss:Data ss:Type="String"></ss:Data></Cell>
    <Cell ss:StyleID="s22"><Data ss:Type="DateTime">2024-11-07T09:00:00.000</Data></Cell>
    <Cell ss:StyleID="s22"><Data ss:Type="DateTime">2024-11-07T10:15:00.000</Data></Cell>
    <Cell><ss:Data ss:Type="String"></ss:Data></Cell>
    <Cell><ss:Data ss:Type="String"></ss:Data></Cell>
    <Cell><ss:Data ss:Type="String">Grumbach, Liz</ss:Data></Cell>
    <Cell><ss:Data ss:Type="String">Tilton, Lauren</ss:Data></Cell>
    <Cell><ss:Data ss:Type="String"></ss:Data></Cell>
    <Cell><ss:Data ss:Type="String"></ss:Data></Cell>
    <Cell><ss:Data ss:Type="String"></ss:Data></Cell>
    <Cell><ss:Data ss:Type="String"></ss:Data></Cell>
    <Cell><ss:Data ss:Type="String">Should this proposal be accepted, and the program committee need to schedule us for 1 hour and 15 minutes, we feel we can accomplish our goals, but 1 hour and 30 minutes would allow us to devote a more significant amount of time to making a digital record of refusal that would live on after the conference. </ss:Data></Cell>
