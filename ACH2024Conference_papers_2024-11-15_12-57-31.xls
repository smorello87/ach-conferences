    <Cell><ss:Data ss:Type="String">ghjensen@uvic.ca</ss:Data></Cell>
    <Cell><ss:Data ss:Type="String"></ss:Data></Cell>
    <Cell><ss:Data ss:Type="String">ghjensen@uvic.ca, siemens@uvic.ca, alancolinarce@uvic.ca, brittamell@gmail.com</ss:Data></Cell>
    <Cell><ss:Data ss:Type="String">Jensen, Graham</ss:Data></Cell>
    <Cell><ss:Data ss:Type="String">ghjensen@uvic.ca</ss:Data></Cell>
    <Cell><ss:Data ss:Type="String"></ss:Data></Cell>
    <Cell><ss:Data ss:Type="String"></ss:Data></Cell>
