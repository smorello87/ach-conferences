    <Cell><ss:Data ss:Type="String">80.0</ss:Data></Cell>
    <Cell><ss:Data ss:Type="String">92.0</ss:Data></Cell>
    <Cell><ss:Data ss:Type="String">60.0</ss:Data></Cell>
    <Cell><ss:Data ss:Type="String">0</ss:Data></Cell>
    <Cell><ss:Data ss:Type="String">2</ss:Data></Cell>
    <Cell><ss:Data ss:Type="String">1</ss:Data></Cell>
