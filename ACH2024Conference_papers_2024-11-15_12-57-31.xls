    <Cell ss:StyleID="s22"><Data ss:Type="DateTime">2024-11-08T15:00:00.000</Data></Cell>
    <Cell ss:StyleID="s22"><Data ss:Type="DateTime">2024-11-08T16:15:00.000</Data></Cell>
    <Cell><ss:Data ss:Type="String"></ss:Data></Cell>
    <Cell><ss:Data ss:Type="String"></ss:Data></Cell>
    <Cell><ss:Data ss:Type="String">Janco, Andy</ss:Data></Cell>
    <Cell><ss:Data ss:Type="String">Rosenblum, Brian</ss:Data></Cell>
    <Cell><ss:Data ss:Type="String"></ss:Data></Cell>
    <Cell><ss:Data ss:Type="String"></ss:Data></Cell>
    <Cell><ss:Data ss:Type="String"></ss:Data></Cell>
    <Cell><ss:Data ss:Type="String"></ss:Data></Cell>
    <Cell><ss:Data ss:Type="String">The temporal focus of the projects considered in this proposal extends from the fifteenth century to the present. We were not able to indicate that above due to the response being limited to three time periods.</ss:Data></Cell>
    <Cell><ss:Data ss:Type="String"></ss:Data></Cell>
