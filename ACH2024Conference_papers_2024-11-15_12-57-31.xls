    <Cell><ss:Data ss:Type="String"></ss:Data></Cell>
    <Cell><ss:Data ss:Type="String"></ss:Data></Cell>
    <Cell><ss:Data ss:Type="String"></ss:Data></Cell>
    <Cell><ss:Data ss:Type="Number">12</ss:Data></Cell>
    <Cell><ss:Data ss:Type="String">Accept as Round</ss:Data></Cell>
    <Cell ss:StyleID="s22"><Data ss:Type="DateTime">2024-09-07T17:36:30.000</Data></Cell>
