   <Row>
    <Cell><ss:Data ss:Type="Number">103</ss:Data></Cell>
    <Cell><ss:Data ss:Type="String">Individual Paper</ss:Data></Cell>
    <Cell><ss:Data ss:Type="String">Wan, Shu</ss:Data></Cell>
    <Cell><ss:Data ss:Type="String">University at Buffalo</ss:Data></Cell>
    <Cell><ss:Data ss:Type="String"></ss:Data></Cell>
    <Cell><ss:Data ss:Type="String">Wan, Shu* (University at Buffalo) &lt;shuwan@buffalo.edu&gt;</ss:Data></Cell>
    <Cell><ss:Data ss:Type="String">Wan, Shu*</ss:Data></Cell>
    <Cell><ss:Data ss:Type="String">Wan, Shu</ss:Data></Cell>
    <Cell><ss:Data ss:Type="String">Wan, Shu*</ss:Data></Cell>
    <Cell><ss:Data ss:Type="String">University at Buffalo</ss:Data></Cell>
