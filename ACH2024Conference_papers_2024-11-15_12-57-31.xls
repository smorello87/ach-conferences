    <Cell><ss:Data ss:Type="String">0</ss:Data></Cell>
    <Cell><ss:Data ss:Type="String"></ss:Data></Cell>
    <Cell><ss:Data ss:Type="Number">1213</ss:Data></Cell>
    <Cell><ss:Data ss:Type="String">Schroeder, Caroline T.</ss:Data></Cell>
