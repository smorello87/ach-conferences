    <Cell><ss:Data ss:Type="String">Murray, Nathan;&#10;Tersigni, Elisa</ss:Data></Cell>
    <Cell><ss:Data ss:Type="String">nathan.murray@algomau.ca;&#10;elisa.tersigni@utoronto.ca</ss:Data></Cell>
