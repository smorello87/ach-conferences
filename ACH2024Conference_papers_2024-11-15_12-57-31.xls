    <Cell><ss:Data ss:Type="String"></ss:Data></Cell>
    <Cell><ss:Data ss:Type="String">Olson, Paula* (Dartmouth College) &lt;paula.l.olson@dartmouth.edu&gt;&#10;Morin, Molly* (Dartmouth College) &lt;molly.c.morin@dartmouth.edu&gt;&#10;Stevens, Nikki* (MIT, United States of America) &lt;nikkilstevens@gmail.com&gt;</ss:Data></Cell>
    <Cell><ss:Data ss:Type="String">Olson, Paula* (2)&#10;Morin, Molly* (2)&#10;Stevens, Nikki* (1)</ss:Data></Cell>
